generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  inactive
  suspended
  pending
}

enum VaultItemType {
  password
  stock_account
  bank_account
  email_account
  server_account
  note
  document
  custom
}

enum ContactPermissionScope {
  notify_only
  request_takeover
  view_partial
  view_all
  export
  inactive_only
}

enum AuditActorType {
  user
  contact
  system
  admin
}

enum AuditRiskLevel {
  low
  medium
  high
  critical
}

enum InheritanceEventStatus {
  pending
  reminding
  grace_period
  contact_verification
  cooldown
  completed
  cancelled
}

enum ContactTakeoverSessionStatus {
  started
  otp_verified
  challenges_verified
  completed
  expired
}

model User {
  id                 String     @id @default(cuid())
  phone              String?    @unique
  email              String?    @unique
  wxOpenid           String?    @unique @map("wx_openid")
  status             UserStatus @default(pending)
  lastLoginAt        DateTime?  @map("last_login_at")
  masterPasswordHash String?    @map("master_password_hash") @db.VarChar(255)
  encryptedVaultKey  String     @map("encrypted_vault_key") @db.LongText
  kdfSalt            String     @map("kdf_salt") @db.VarChar(128)
  kdfParams          Json       @map("kdf_params")
  mfaEnabled         Boolean    @default(false) @map("mfa_enabled")
  mfaSecret          String?    @map("mfa_secret") @db.VarChar(128)
  encryptedVaultKeyByRecovery String? @map("encrypted_vault_key_by_recovery") @db.LongText
  recoveryKeyHint    String?    @map("recovery_key_hint") @db.VarChar(255)
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  loginDevices      LoginDevice[]
  vaultItems        VaultItem[]
  vaultFiles        VaultFile[]
  albums            Album[]
  trustedContacts   TrustedContact[]
  inheritanceRules  InheritanceRule[]
  inheritanceEvents InheritanceEvent[]
  notificationLogs  NotificationLog[]
  auditLogs         AuditLog[]
  contactTakeoverInvites ContactTakeoverInvite[]
  contactTakeoverSessions ContactTakeoverSession[]

  inheritancePausedUntil DateTime? @map("inheritance_paused_until")

  @@map("users")
}

model LoginDevice {
  id           String    @id @default(cuid())
  userId       String    @map("user_id")
  deviceId     String    @map("device_id") @db.VarChar(64)
  deviceName   String?   @map("device_name") @db.VarChar(255)
  ip           String?   @db.VarChar(64)
  userAgent    String?   @map("user_agent") @db.Text
  lastActiveAt DateTime  @map("last_active_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("login_devices")
}

model VaultItem {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  type              VaultItemType
  titleCiphertext   String        @map("title_ciphertext") @db.Text
  encryptedPayload  String        @map("encrypted_payload") @db.LongText
  encryptedMetadata String?       @map("encrypted_metadata") @db.Text
  favorite          Boolean       @default(false)
  deletedAt         DateTime?     @map("deleted_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("vault_items")
}

model Album {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  encryptedName       String   @map("encrypted_name") @db.Text
  encryptedDescription String? @map("encrypted_description") @db.Text
  encryptedCoverFileId String? @map("encrypted_cover_file_id") @db.VarChar(64)
  createdAt           DateTime @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  files VaultFile[]

  @@index([userId])
  @@map("albums")
}

model VaultFile {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  albumId           String?  @map("album_id")
  fileType          String   @map("file_type")
  storagePath       String   @map("storage_path") @db.VarChar(512)
  encryptedFileKey  String   @map("encrypted_file_key") @db.Text
  fileHash          String   @map("file_hash") @db.VarChar(128)
  fileSize          Int      @map("file_size")
  mimeType          String   @map("mime_type")
  encryptedMetadata String?  @map("encrypted_metadata") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("vault_files")
}

model TrustedContact {
  id               String                 @id @default(cuid())
  userId           String                 @map("user_id")
  nameCiphertext   String                 @map("name_ciphertext") @db.Text
  phoneCiphertext  String                 @map("phone_ciphertext") @db.Text
  emailCiphertext  String                 @map("email_ciphertext") @db.Text
  relationCiphertext String?              @map("relation_ciphertext") @db.Text
  permissionScope  ContactPermissionScope @map("permission_scope")
  priority         Int                    @default(0)
  status           String                 @default("active")
  encryptedVaultKeyForContact String?     @map("encrypted_vault_key_for_contact") @db.LongText
  phoneLookupHash  String?                @map("phone_lookup_hash") @db.VarChar(128)
  emailLookupHash  String?                @map("email_lookup_hash") @db.VarChar(128)
  notifyPhone      String?                @map("notify_phone") @db.VarChar(20)
  notifyEmail      String?                @map("notify_email") @db.VarChar(255)
  createdAt        DateTime               @default(now()) @map("created_at")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenges ContactChallenge[]
  takeoverInvites ContactTakeoverInvite[]
  takeoverSessions ContactTakeoverSession[]

  @@index([userId])
  @@map("trusted_contacts")
}

model InheritanceRule {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  inactiveYears       Int      @map("inactive_years")
  reminderFrequency   String   @map("reminder_frequency")
  gracePeriodMonths   Int      @map("grace_period_months")
  requireMultiContact Boolean  @default(false) @map("require_multi_contact")
  unlockPolicy        Json?    @map("unlock_policy")
  status              String   @default("active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("inheritance_rules")
}

model InheritanceEvent {
  id                 String                 @id @default(cuid())
  userId             String                 @map("user_id")
  eventType          String                 @map("event_type")
  triggerAt          DateTime               @map("trigger_at")
  status             InheritanceEventStatus @default(pending)
  currentStage       String                 @map("current_stage")
  lastReminderAt     DateTime?              @map("last_reminder_at")
  graceEndsAt        DateTime?              @map("grace_ends_at")
  cooldownEndsAt     DateTime?              @map("cooldown_ends_at")
  contactsNotifiedAt DateTime?              @map("contacts_notified_at")
  metadata           Json?
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  takeoverInvites ContactTakeoverInvite[]
  takeoverSessions ContactTakeoverSession[]

  @@index([userId])
  @@index([status])
  @@map("inheritance_events")
}

enum NotificationChannel {
  email
  sms
  system
}

enum NotificationStatus {
  sent
  failed
  skipped
}

model NotificationLog {
  id               String              @id @default(cuid())
  userId           String              @map("user_id")
  channel          NotificationChannel
  notificationType String              @map("notification_type")
  target           String?
  status           NotificationStatus
  errorMessage     String?             @map("error_message") @db.Text
  createdAt        DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("notification_logs")
}

model ContactChallenge {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  contactId         String   @map("contact_id")
  encryptedQuestion String   @map("encrypted_question") @db.Text
  encryptedAnswerHash String @map("encrypted_answer_hash") @db.Text
  questionLabel     String?  @map("question_label")
  required          Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  contact TrustedContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("contact_challenges")
}

model ContactTakeoverInvite {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  contactId String   @map("contact_id")
  eventId   String   @map("event_id")
  tokenHash String   @unique @map("token_hash") @db.VarChar(128)
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact TrustedContact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  event   InheritanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sessions ContactTakeoverSession[]

  @@index([contactId])
  @@index([eventId])
  @@map("contact_takeover_invites")
}

model ContactTakeoverSession {
  id                 String                       @id @default(cuid())
  userId             String                       @map("user_id")
  contactId          String                       @map("contact_id")
  eventId            String                       @map("event_id")
  inviteId           String                       @map("invite_id")
  status             ContactTakeoverSessionStatus @default(started)
  otpHash            String?                      @map("otp_hash") @db.VarChar(128)
  otpExpiresAt       DateTime?                    @map("otp_expires_at")
  otpChannel         String?                      @map("otp_channel")
  otpTarget          String?                      @map("otp_target")
  challengesPassedAt DateTime?                    @map("challenges_passed_at")
  completedAt        DateTime?                    @map("completed_at")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")

  user    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact TrustedContact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  event   InheritanceEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invite  ContactTakeoverInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([inviteId])
  @@map("contact_takeover_sessions")
}

model AuditLog {
  id        String         @id @default(cuid())
  userId    String?        @map("user_id")
  actorType AuditActorType @map("actor_type")
  actorId   String?        @map("actor_id")
  action    String
  ip        String?
  device    String?
  riskLevel AuditRiskLevel @default(low) @map("risk_level")
  createdAt DateTime       @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model IpBlacklist {
  id        String   @id @default(cuid())
  ip        String   @unique @db.VarChar(64)
  reason    String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ip_blacklist")
}
