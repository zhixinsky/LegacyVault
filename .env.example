# VaultPass 环境变量说明
# 微信云托管：在「服务 express-gsc8 → 版本配置 → 环境变量」中配置下方「云托管必填」项
# 本地开发：复制本文件为 .env 并填写

# ==================== 云托管必填 ====================

# 数据库（二选一）
# 方式 A：完整连接串（本地开发常用）
# DATABASE_URL="mysql://user:pass@内网主机:3306/vaultpass"
# 方式 B：微信云托管绑定 MySQL 后自动注入，无需手写 DATABASE_URL：
# MYSQL_ADDRESS=内网地址或 host:3306
# MYSQL_USERNAME=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=vaultpass   （可选，默认 vaultpass）

JWT_SECRET=生产环境强随机字符串
JWT_EXPIRES_IN=7d

API_PORT=80
ADMIN_API_KEY=生产环境强随机字符串

STORAGE_PROVIDER=wechat_cos
STORAGE_LOCAL_FALLBACK=false
TCB_ENV_ID=
COS_BUCKET=
COS_REGION=ap-shanghai
COS_PREFIX=vaultpass/

WX_APPID=
WX_APP_SECRET=
WX_USE_OPENAPI=true
WX_PHONE_API_MODE=open
WX_OPEN_API_BASE=http://api.weixin.qq.com
WX_SCAN_LOGIN_PAGE=pages/scan-login/scan-login
WX_WX_BIND_PAGE=pages/wx-bind-scan/wx-bind-scan
WX_QRCODE_ENV_VERSION=release
WX_QRCODE_CHECK_PATH=false

SMS_PROVIDER=emay
EMAY_APPID=
EMAY_SECRETKEY=
EMAY_BASE_URL=http://www.btom.cn:8080
EMAY_AUTO_CREATE_TEMPLATES=false
EMAY_TEMPLATE_ID_OTP=
EMAY_TEMPLATE_ID_INHERITANCE=
EMAY_TEMPLATE_ID_CONTACT_NOTICE=
EMAY_TEMPLATE_ID_SECURITY_ALERT=

INHERITANCE_CRON_ENABLED=true

# ==================== 云托管建议配置 ====================

# 容器临时目录即可；STORAGE_LOCAL_FALLBACK=false 时几乎不用
STORAGE_PATH=./storage

# 遗产提醒 / 安全告警邮件（不用邮件可留空，仅短信仍可用）
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ==================== 云托管一般不需要 ====================

# 仅当部署了 PC Web（apps/web）且向联系人发邮件时填写；短信/小程序接管可不配
# WEB_APP_URL=https://你的Web域名

# 代码里 API 前缀已固定为 api/v1（main.ts），此项仅 cloud:smoke-check 脚本读取
# API_PREFIX=api/v1

# 仅当开放接口服务绑定的小程序与 WX_APPID 不同时填写
# WX_OPENAPI_FROM_APPID=

# 仅 SMS_PROVIDER=aliyun 时需要
# SMS_ACCESS_KEY=
# SMS_SECRET_KEY=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# 可选静态 IP 黑名单（与 Admin 后台合并）
# IP_BLACKLIST=

# ==================== 仅本地命令行脚本 ====================
# SMOKE_API_URL=https://你的服务/api/v1
# MIGRATE_DRY_RUN=true

# ==================== 云托管单端口部署（API + PC Web） ====================
# Dockerfile 会将 apps/web 构建产物放入 apps/api/public，Nest 同端口 80 提供：
#   https://域名/              → PC Web
#   https://域名/api/v1/...    → API
# 小程序仍用云托管公网域名 + /api/v1（见 apps/miniprogram/.env.production）
# PC Web 构建使用 apps/web/.env.production 中 VITE_API_BASE_URL=/api/v1
# 可选：部署 PC Web 后配置 WEB_APP_URL=https://vault.dokor.cn（遗产邮件链接）

# ==================== 微信云托管「开放接口服务」令牌白名单 ====================
# 配置后须重新发布服务：
#   /wxa/business/getuserphonenumber
#   /sns/jscode2session
#   /wxa/getwxacodeunlimit
#   /tcb/uploadfile、/tcb/batchdownloadfile、/tcb/deletefile
